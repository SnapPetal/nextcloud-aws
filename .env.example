# Domain Configuration
DOMAIN=cloud.thonbecker.biz

# Local MariaDB Configuration
DB_ROOT_PASSWORD=your_strong_root_password_here
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASSWORD=your_strong_database_password_here

# Data Storage Path
DATA_PATH=/var/lib/nextcloud/data

# S3 Backup Configuration (legacy — single MariaDB backup bucket)
S3_BUCKET=your-backup-bucket-name

# Dedicated DB Backup Bucket for MariaDB + PostgreSQL (7-day lifecycle)
# Managed by CDK (HomeWeb db-backup-stack). Configure with: ./scripts/setup-s3-backup.sh
S3_DB_BACKUP_BUCKET=nextcloud-db-backups-thonbecker

# Ente Configuration
ENTE_POSTGRES_USER=ente
ENTE_POSTGRES_PASSWORD=your_strong_ente_db_password
ENTE_POSTGRES_DB=ente_db
ENTE_S3_BUCKET=your-ente-photos-bucket
ENTE_S3_REGION=us-east-1
ENTE_S3_ACCESS_KEY=your_access_key
ENTE_S3_SECRET_KEY=your_secret_key
ENTE_JWT_SECRET=your_jwt_secret_hex
ENTE_KEY_ENCRYPTION=your_base64_encryption_key
ENTE_KEY_HASH=your_base64_hash_key
ENTE_SMTP_USERNAME=your_gmail_address
ENTE_SMTP_PASSWORD=your_gmail_app_password

# Netdata / Observability
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
NETDATA_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:your-alerts-topic
NETDATA_CLAIM_TOKEN=your_netdata_claim_token
NETDATA_CLAIM_ROOMS=your_netdata_room_id

# Vaultwarden Configuration
VAULTWARDEN_ADMIN_TOKEN=your_vaultwarden_admin_token
VAULTWARDEN_SMTP_FROM=your_gmail_address@gmail.com
VAULTWARDEN_SMTP_USERNAME=your_gmail_address@gmail.com
VAULTWARDEN_SMTP_PASSWORD=your_gmail_app_password

# Personal Website Configuration
PERSONAL_AWS_ACCESS_KEY_ID=your_aws_access_key
PERSONAL_AWS_SECRET_ACCESS_KEY=your_aws_secret_key
PERSONAL_AWS_REGION=us-east-1
PERSONAL_NEXTCLOUD_USERNAME=your_nextcloud_username
PERSONAL_NEXTCLOUD_APP_PASSWORD=your_nextcloud_app_password
PERSONAL_COGNITO_USER_POOL_ID=your_cognito_user_pool_id
PERSONAL_COGNITO_CLIENT_ID=your_cognito_client_id
PERSONAL_COGNITO_CLIENT_SECRET=your_cognito_client_secret
PERSONAL_DB_USERNAME=postgres
PERSONAL_DB_PASSWORD=your_strong_personal_db_password
PERSONAL_PERENUAL_API_KEY=your_perenual_api_key
SKATETRICKS_UPLOAD_MAX_FILE_SIZE=500MB
SKATETRICKS_UPLOAD_PRESIGN_DURATION=15m
SKATETRICKS_TRANSCODING_INPUT_BUCKET=cdn-page-stack-processedmediabucket446d3976-oonhpdwdpfzq
SKATETRICKS_TRANSCODING_OUTPUT_BUCKET=cdn-page-stack-processedmediabucket446d3976-oonhpdwdpfzq
SKATETRICKS_MEDIACONVERT_ROLE_ARN=arn:aws:iam::664759038511:role/homeweb-skatetricks-mediaconvert-role
SKATETRICKS_CDN_DOMAIN=https://cdn.thonbecker.com
