# Domain Configuration
DOMAIN=cloud.thonbecker.biz

# Local MariaDB Configuration
DB_ROOT_PASSWORD=your_strong_root_password_here
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASSWORD=your_strong_database_password_here

# Data Storage Path (mount point for separate volume)
DATA_PATH=/mnt/nextcloud-data

# S3 Backup Configuration (legacy — single MariaDB backup bucket)
S3_BUCKET=your-backup-bucket-name

# Dedicated DB Backup Bucket for MariaDB + PostgreSQL (7-day lifecycle)
# Managed by CDK (HomeWeb db-backup-stack). Configure with: ./scripts/setup-s3-backup.sh
S3_DB_BACKUP_BUCKET=nextcloud-db-backups-thonbecker

# Ente Configuration
ENTE_POSTGRES_USER=ente
ENTE_POSTGRES_PASSWORD=your_strong_ente_db_password
ENTE_POSTGRES_DB=ente_db
ENTE_S3_BUCKET=your-ente-photos-bucket
ENTE_S3_REGION=us-east-1
ENTE_S3_ACCESS_KEY=your_access_key
ENTE_S3_SECRET_KEY=your_secret_key
ENTE_JWT_SECRET=your_jwt_secret_hex
ENTE_KEY_ENCRYPTION=your_base64_encryption_key
ENTE_KEY_HASH=your_base64_hash_key
ENTE_SMTP_USERNAME=your_gmail_address
ENTE_SMTP_PASSWORD=your_gmail_app_password

# Netdata / Observability
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
NETDATA_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:your-alerts-topic

# Vaultwarden Configuration
VAULTWARDEN_ADMIN_TOKEN=your_vaultwarden_admin_token
VAULTWARDEN_SMTP_FROM=your_gmail_address@gmail.com
VAULTWARDEN_SMTP_USERNAME=your_gmail_address@gmail.com
VAULTWARDEN_SMTP_PASSWORD=your_gmail_app_password

